# Database (Neon Postgres)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# LLM — Google Gemini 2.0 Flash (үнэгүй tier өгөөмөр)
GEMINI_API_KEY=""

# Image generation — multi-provider (cloudflare → pollinations → placeholder)
# Provider priority: cloudflare | pollinations | placeholder
IMAGE_PROVIDER="cloudflare"
IMAGE_FAILOVER="true"

# Cloudflare Workers AI (default provider — үнэгүй tier байдаг)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
# Optional: өөр model ашиглах бол (default: @cf/black-forest-labs/flux-1-schnell)
# CF_IMAGE_MODEL="@cf/black-forest-labs/flux-1-schnell"

# fal.ai (хуучин provider — хэрэглэхгүй болсон, хэрэгтэй бол IMAGE_PROVIDER=fal гэж тохируулна)
FAL_KEY=""

# Vector DB — Qdrant Cloud
QDRANT_URL=""
QDRANT_API_KEY=""

# QPay (https://developer.qpay.mn)
QPAY_USERNAME=""
QPAY_PASSWORD=""
QPAY_INVOICE_CODE=""
QPAY_BASE_URL="https://merchant.qpay.mn/v2"

# SocialPay (Golomt)
SOCIALPAY_USERNAME=""
SOCIALPAY_PASSWORD=""
SOCIALPAY_TERMINAL=""
SOCIALPAY_BASE_URL="https://service.iwebgate.mn/ecomm"

# KhanBank Corporate Gateway
KHANBANK_CLIENT_ID=""
KHANBANK_CLIENT_SECRET=""
KHANBANK_TERMINAL_ID=""
KHANBANK_BASE_URL="https://api.khanbank.com"

# Golomt Bank Corporate Gateway
GOLOMT_CLIENT_ID=""
GOLOMT_CLIENT_SECRET=""
GOLOMT_BASE_URL="https://egateway.golomtbank.com"

# Platform
PLATFORM_ROOT_DOMAIN="platform.mn"
APP_URL="http://localhost:3000"
