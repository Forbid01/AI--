generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  mn
  en
}

enum SiteStatus {
  draft
  published
  archived
}

enum TonePreset {
  formal
  friendly
  premium
  sales
}

enum PaymentProvider {
  qpay
  socialpay
  khanbank
  golomt
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
  cancelled
}

enum Plan {
  free
  starter
  pro
}

enum AiJobType {
  content
  translate
  image
  layout
}

enum SiteMode {
  template
  ai_composed
}

enum AiJobStatus {
  queued
  running
  done
  failed
}

enum Role {
  user
  admin
  superadmin
}

model User {
  id                      String         @id @default(cuid())
  email                   String         @unique
  name                    String?
  passwordHash            String?
  preferredLocale         Locale         @default(mn)
  role                    Role           @default(user)
  emailVerified           DateTime?
  emailVerificationToken  String?        @unique
  passwordResetToken      String?        @unique
  passwordResetExpires    DateTime?
  marketingOptIn          Boolean        @default(false)
  deletedAt               DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  sites                   Site[]
  subscription            Subscription?
  payments                Payment[]
  apiTokens               ApiToken[]
  auditLogs               AuditLog[]

  @@index([deletedAt])
  @@index([role])
}

model Site {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId    String
  mode          SiteMode       @default(template)
  name          String
  subdomain     String         @unique
  customDomain  String?        @unique
  customDomainVerified Boolean @default(false)
  domainVerificationToken String?
  status        SiteStatus     @default(draft)
  defaultLocale Locale         @default(mn)
  enabledLocales Locale[]      @default([mn])
  tone          TonePreset     @default(friendly)
  business      Json           // business info (name, industry, services, contact, etc.)
  screenshot    String?        // public URL of rendered site thumbnail (set on publish)
  analyticsTag  String?        // user's GA4 / Plausible tag to inject
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  content       SiteContent[]
  theme         SiteTheme?
  assets        SiteAsset[]
  aiJobs        AiJob[]
  submissions   ContactSubmission[]
  analytics     SiteAnalytics[]
  webhooks      Webhook[]

  @@index([userId])
  @@index([status, deletedAt])
}

model SiteContent {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  locale    Locale
  sections  Json     // { hero: {...}, about: {...}, services: [...], ... }
  layout    Json?    // [{ type, variant }, ...] — only set when mode = ai_composed
  history   Json?    // last N versions, [{ sections, layout, at }]
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, locale])
}

model SiteTheme {
  id         String   @id @default(cuid())
  siteId     String   @unique
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  primary    String   @default("#0f172a")
  accent     String   @default("#f59e0b")
  background String   @default("#ffffff")
  foreground String   @default("#0f172a")
  fontHeading String  @default("Inter")
  fontBody   String   @default("Inter")
  radius     String   @default("md")
  updatedAt  DateTime @updatedAt
}

model SiteAsset {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  kind      String   // hero, gallery, logo, favicon
  url       String   // data: URL or public CDN URL
  cdnUrl    String?  // when uploaded to R2/S3, this is populated; prefer cdnUrl over url
  prompt    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([siteId])
}

model AiJob {
  id         String      @id @default(cuid())
  siteId     String
  site       Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type       AiJobType
  status     AiJobStatus @default(queued)
  input      Json
  output     Json?
  error      String?
  costCents  Int         @default(0)
  tokenCount Int         @default(0)
  latencyMs  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([siteId, status])
  @@index([type, createdAt])
}

model Subscription {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       Plan     @default(free)
  startedAt  DateTime @default(now())
  expiresAt  DateTime?
  autoRenew  Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model Payment {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        PaymentProvider
  providerInvoiceId String?
  providerTxnId   String?
  amount          Int             // MNT, бүхэл утгаар
  currency        String          @default("MNT")
  status          PaymentStatus   @default(pending)
  description     String?
  meta            Json?
  invoicePdfUrl   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, status])
  @@index([provider, providerInvoiceId])
}

// Rate limiting + webhook replay protection.
// Key: arbitrary string (user:action:resourceHash, webhook signature, etc.)
// Unique by (key, scope) so the same key can exist per scope.
model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String
  scope     String   // "payment.create", "webhook.qpay", etc.
  userId    String?
  responseBody Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([key, scope])
  @@index([expiresAt])
}

// Admin audit log — who did what, when, from where.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // "site.delete", "user.ban", "payment.refund"
  entityType String?  // "Site", "User", "Payment"
  entityId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

// User-facing API tokens for public API access.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  scopes     String[]  @default([]) // read:sites, write:sites, admin
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// Outgoing webhooks on platform events.
model Webhook {
  id         String    @id @default(cuid())
  siteId     String
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url        String
  events     String[]  @default([]) // site.published, payment.succeeded, etc.
  secret     String    // HMAC signing secret
  active     Boolean   @default(true)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  failureCount Int     @default(0)
  createdAt  DateTime  @default(now())

  @@index([siteId, active])
}

// Public site contact-form submissions.
model ContactSubmission {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name       String
  email      String
  phone      String?
  message    String
  ip         String?
  userAgent  String?
  spamScore  Float    @default(0)
  handled    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([siteId, createdAt])
}

// Privacy-friendly site visitor analytics (daily-aggregated rollups).
model SiteAnalytics {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  day        DateTime @db.Date
  pageViews  Int      @default(0)
  uniqueVisitors Int  @default(0)
  referrers  Json     @default("{}")
  devices    Json     @default("{}")
  countries  Json     @default("{}")

  @@unique([siteId, day])
  @@index([day])
}
