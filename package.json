{
  "name": "aiweb",
  "version": "0.0.1",
  "private": true,
  "description": "AI-powered Mongolian small business website builder",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "pnpm --filter @aiweb/db run generate",
    "db:migrate": "pnpm --filter @aiweb/db run migrate",
    "db:studio": "pnpm --filter @aiweb/db run studio",
    "gen:covers": "node scripts/gen-covers.mjs"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
