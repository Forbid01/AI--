{
  "name": "aiweb",
  "version": "0.0.1",
  "private": true,
  "description": "AI-powered Mongolian small business website builder",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @aiweb/db prisma generate",
    "db:migrate": "pnpm --filter @aiweb/db prisma migrate dev",
    "db:studio": "pnpm --filter @aiweb/db prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
